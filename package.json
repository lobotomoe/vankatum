{
  "name": "vankatum",
  "version": "0.1.0",
  "description": "Reliable Armenian (hy) hyphenation for browsers and typesetting — syllabification-based (Eastern/reformed orthography).",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "armenian",
    "hyphenation",
    "syllabification",
    "hy",
    "typesetting",
    "hyphen",
    "tex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobotomoe/vankatum.git"
  },
  "homepage": "https://github.com/lobotomoe/vankatum#readme",
  "bugs": "https://github.com/lobotomoe/vankatum/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "src",
    "docs/SPEC.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
